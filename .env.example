PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# En Vercel usar la URL publica, por ejemplo:
# CORS_ORIGINS=https://nombre-del-proyecto.vercel.app

JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRES_IN=1h

ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456
USER_EMAIL=user@gmail.com
USER_PASSWORD=123456

FIREBASE_API_KEY=replace_with_firebase_api_key
FIREBASE_AUTH_DOMAIN=replace_with_project.firebaseapp.com
FIREBASE_PROJECT_ID=replace_with_project_id
FIREBASE_STORAGE_BUCKET=replace_with_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
FIREBASE_APP_ID=replace_with_app_id
FIREBASE_MEASUREMENT_ID=replace_with_measurement_id_optional

FIRESTORE_PRODUCTS_COLLECTION=products
FIRESTORE_USERS_COLLECTION=users
